---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  items: FAQItem[];
  includeSchema?: boolean;
}

const { 
  title = 'Frequently asked questions',
  eyebrow = 'Good questions',
  description,
  items,
  includeSchema = true
} = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

{includeSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

<section class="py-24 lg:py-32">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-4">
        <div class="sticky top-24">
          <p class="eyebrow mb-5">{eyebrow}</p>
          <h2 class="font-display text-display-md text-moss leading-[1.05]">
            {title}
          </h2>
          {description && (
            <p class="mt-6 text-ink/70 leading-relaxed">
              {description}
            </p>
          )}
        </div>
      </div>

      <div class="lg:col-span-8">
        <div class="divide-y divide-moss/10 border-y border-moss/10">
          {items.map((item) => (
            <details class="group py-6 lg:py-7">
              <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
                <h3 class="font-display text-xl lg:text-2xl text-moss leading-snug flex-1">
                  {item.question}
                </h3>
                <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-full border border-moss/20 transition-all duration-300 group-hover:border-terra group-open:bg-moss group-open:border-moss group-open:rotate-45">
                  <svg class="w-4 h-4 text-moss group-open:text-cream transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                </div>
              </summary>
              <div class="mt-5 text-ink/75 text-[1.0625rem] leading-relaxed max-w-2xl prose-custom">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
