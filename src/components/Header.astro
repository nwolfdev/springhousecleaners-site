---
import { primaryNav, site } from '../config.js';
---

<header class="sticky top-0 z-50 bg-cream/85 backdrop-blur-md border-b border-moss/10">
  <div class="container-custom flex items-center justify-between h-[72px]">
    <a href="/" class="flex items-center gap-2.5 group shrink-0" aria-label="Spring Cleaning — home">
      <img 
        src="/logo-mark.png" 
        alt="" 
        class="h-10 w-auto transition-transform duration-300 group-hover:scale-105"
        width="60"
        height="40"
      />
      <div class="flex items-baseline gap-1.5 hidden sm:flex">
        <span class="font-display text-xl font-semibold text-moss tracking-tight leading-none">
          Spring
        </span>
        <span class="text-[0.65rem] font-medium tracking-[0.18em] uppercase text-terra leading-none">
          Cleaning
        </span>
      </div>
    </a>

    <nav class="hidden lg:flex items-center gap-9">
      {primaryNav.map(item => (
        <a href={item.href} class="text-sm font-medium text-ink hover:text-terra transition-colors relative group">
          {item.label}
          <span class="absolute left-0 -bottom-1 w-0 h-px bg-terra transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a 
        href={`tel:${site.phoneTel}`} 
        class="hidden md:inline-flex items-center gap-2 text-sm font-medium text-moss hover:text-terra transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="tabular-nums">{site.phone}</span>
      </a>
      <a href="/contact/" class="btn-accent text-xs">
        Book Now
      </a>
      <button
        id="mobile-toggle"
        class="lg:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
        aria-label="Menu"
      >
        <span class="block w-5 h-px bg-moss"></span>
        <span class="block w-5 h-px bg-moss"></span>
        <span class="block w-5 h-px bg-moss"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-moss/10 bg-cream">
    <nav class="container-custom py-6 flex flex-col gap-1">
      {primaryNav.map(item => (
        <a href={item.href} class="py-3 text-base font-medium text-ink hover:text-terra border-b border-moss/5">
          {item.label}
        </a>
      ))}
      <a 
        href={`tel:${site.phoneTel}`} 
        class="mt-3 py-3 text-base font-medium text-terra inline-flex items-center gap-2"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {site.phone}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
