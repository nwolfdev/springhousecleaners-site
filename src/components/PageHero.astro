---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  breadcrumb?: { label: string; href: string }[];
}
const { eyebrow, title, description, breadcrumb = [] } = Astro.props;

const breadcrumbSchema = breadcrumb.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumb.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.label,
    "item": `https://springhousecleaners.com${crumb.href}`
  }))
} : null;
---

{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

<section class="relative pt-12 lg:pt-20 pb-16 lg:pb-20 overflow-hidden border-b border-moss/10">
  <div class="absolute top-0 -right-32 w-96 h-96 rounded-full bg-moss/[0.04] blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 -left-32 w-96 h-96 rounded-full bg-terra/[0.03] blur-3xl pointer-events-none"></div>

  <div class="container-custom relative">
    {breadcrumb.length > 0 && (
      <nav class="mb-8 flex items-center gap-2 text-xs text-ink/50" aria-label="Breadcrumb">
        {breadcrumb.map((crumb, i) => (
          <>
            <a href={crumb.href} class="hover:text-moss transition-colors">{crumb.label}</a>
            {i < breadcrumb.length - 1 && <span class="text-ink/30">/</span>}
          </>
        ))}
      </nav>
    )}

    <div class="max-w-4xl">
      {eyebrow && <p class="eyebrow mb-6">{eyebrow}</p>}
      <h1 class="font-display text-display-lg lg:text-display-xl text-moss leading-[0.95] tracking-tight">
        <slot name="title">{title}</slot>
      </h1>
      {description && (
        <p class="mt-8 text-lg lg:text-xl text-ink/70 leading-relaxed max-w-2xl">
          {description}
        </p>
      )}
    </div>
  </div>
</section>
