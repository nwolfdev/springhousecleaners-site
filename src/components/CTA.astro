---
import { site } from '../config.js';

export interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
}
const {
  eyebrow = 'Ready to breathe easy?',
  title = 'Let\'s give your home the care it deserves.',
  description = 'Free quote, no pressure. We\'ll map out exactly what you need — and what it costs — before you commit to anything.',
  primaryLabel = 'Get your free quote',
  primaryHref = '/contact/'
} = Astro.props;
---

<section class="py-24 lg:py-36 relative overflow-hidden">
  <div class="container-custom">
    <div class="relative bg-cream-200 border border-moss/10 p-12 lg:p-20 overflow-hidden">
      <!-- Subtle decorative element -->
      <div class="absolute -bottom-20 -right-20 w-80 h-80 rounded-full bg-terra/5 blur-3xl"></div>
      <div class="absolute -top-10 -left-10 w-60 h-60 rounded-full bg-moss/5 blur-3xl"></div>

      <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-8">
          <p class="eyebrow mb-5">{eyebrow}</p>
          <h2 class="font-display text-display-md lg:text-display-lg text-moss leading-[1.02]">
            {title}
          </h2>
          {description && (
            <p class="mt-6 text-lg text-ink/70 max-w-xl leading-relaxed">
              {description}
            </p>
          )}
        </div>
        <div class="lg:col-span-4 flex flex-col gap-4 lg:items-end">
          <a href={primaryHref} class="btn-primary w-full lg:w-auto">
            {primaryLabel}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <p class="text-sm text-ink/50 lg:text-right">
            Or call <a href={`tel:${site.phoneTel}`} class="text-moss hover:text-terra font-medium tabular-nums">{site.phone}</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
