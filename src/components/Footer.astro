---
import { site, services, cities, primaryNav } from '../config.js';
---

<footer class="bg-moss text-cream mt-32">
  <div class="container-custom py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-5">
        <div class="flex items-baseline gap-2 mb-5">
          <span class="font-display text-3xl font-semibold">Spring</span>
          <span class="text-xs font-medium tracking-[0.2em] uppercase text-terra-200">Cleaning</span>
        </div>
        <p class="text-cream/75 text-lg max-w-md leading-relaxed font-display italic">
          "A home, made to feel like one again."
        </p>
        <div class="mt-10 space-y-2 text-sm text-cream/70">
          <p>{site.serviceArea}</p>
          <p>
            <a href={`mailto:${site.email}`} class="hover:text-terra-200 transition-colors">
              {site.email}
            </a>
          </p>
          <p>{site.hours}</p>
        </div>
      </div>

      <!-- Services -->
      <div class="lg:col-span-3">
        <h4 class="text-xs font-medium tracking-[0.2em] uppercase text-terra-200 mb-5">
          Services
        </h4>
        <ul class="space-y-2.5 text-sm">
          {services.map(s => (
            <li>
              <a href={`/services/${s.slug}/`} class="text-cream/85 hover:text-cream transition-colors">
                {s.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Areas -->
      <div class="lg:col-span-2">
        <h4 class="text-xs font-medium tracking-[0.2em] uppercase text-terra-200 mb-5">
          Service Area
        </h4>
        <ul class="space-y-2.5 text-sm">
          {cities.slice(0, 8).map(c => (
            <li>
              <a href={`/cities/${c.slug}/`} class="text-cream/85 hover:text-cream transition-colors">
                {c.name}
              </a>
            </li>
          ))}
          <li><a href="/cities/" class="text-terra-200 hover:text-cream transition-colors">View all →</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div class="lg:col-span-2">
        <h4 class="text-xs font-medium tracking-[0.2em] uppercase text-terra-200 mb-5">
          Company
        </h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/about/" class="text-cream/85 hover:text-cream transition-colors">About</a></li>
          <li><a href="/blog/" class="text-cream/85 hover:text-cream transition-colors">Journal</a></li>
          <li><a href="/contact/" class="text-cream/85 hover:text-cream transition-colors">Contact</a></li>
          <li><a href="/privacy-policy/" class="text-cream/60 hover:text-cream transition-colors">Privacy</a></li>
          <li><a href="/terms-of-service/" class="text-cream/60 hover:text-cream transition-colors">Terms</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-cream/10 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-cream/50">
      <p>© {new Date().getFullYear()} {site.legalName}. All rights reserved.</p>
      <p>Crafted with care in Spring, Texas.</p>
    </div>
  </div>
</footer>
