---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../config.js';
---

<Base 
  title="Book a Cleaning — Spring Cleaning"
  description="Book your cleaning online in minutes. See pricing, pick a date, and schedule your recurring maid service, deep clean, move-in/out, or office cleaning in the Houston area."
>
  <PageHero
    eyebrow="Book online"
    title="Book your cleaning in minutes."
    description="See pricing, pick a date, and schedule instantly. Or call us at (832) 224-6617 if you'd rather talk to a human first."
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Book', href: '/contact/' }
    ]}
  />

  <section class="py-16 lg:py-24">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <!-- Booking widget -->
        <div class="lg:col-span-8">
          <div class="bg-cream border border-moss/10 p-4 lg:p-8">
            <!-- BookingKoala embed -->
            <iframe 
              src="https://springcleaning.bookingkoala.com/booknow?embed=true" 
              style="border:none; height:1200px;" 
              width="100%" 
              scrolling="no"
              title="Book a cleaning with Spring Cleaning"
            ></iframe>
            <script src="https://springcleaning.bookingkoala.com/resources/embed.js" defer></script>
          </div>
          <p class="mt-4 text-xs text-ink/50">
            Having trouble with the booking form? Call us at <a href={`tel:${site.phoneTel}`} class="text-moss underline hover:text-terra">{site.phone}</a> and we'll get you scheduled.
          </p>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4 lg:pl-4">
          <div class="sticky top-24 space-y-6">
            <div class="bg-moss text-cream p-8 relative overflow-hidden">
              <div class="absolute -bottom-10 -right-10 w-40 h-40 rounded-full bg-terra/20 blur-3xl"></div>
              <div class="relative">
                <p class="eyebrow text-terra-200 mb-4">Prefer to call?</p>
                <a 
                  href={`tel:${site.phoneTel}`}
                  class="font-display text-3xl hover:text-terra-200 transition-colors block"
                >
                  {site.phone}
                </a>
                <p class="mt-6 eyebrow text-terra-200 mb-3">Or email us</p>
                <a 
                  href={`mailto:${site.email}`}
                  class="text-cream/90 hover:text-terra-200 transition-colors break-all"
                >
                  {site.email}
                </a>
              </div>
            </div>

            <div class="bg-cream-200 border border-moss/10 p-8">
              <p class="eyebrow mb-4">Service hours</p>
              <p class="font-display text-xl text-moss leading-tight mb-2">
                {site.hours}
              </p>
              <p class="text-sm text-ink/60 leading-relaxed">
                Closed Sundays. Scheduling windows may vary seasonally.
              </p>
            </div>

            <div class="bg-cream-50 border border-moss/10 p-8">
              <p class="eyebrow mb-4">Service area</p>
              <p class="text-ink/75 leading-relaxed text-sm">
                {site.serviceArea}.
              </p>
              <a href="/cities/" class="mt-4 inline-flex items-center gap-1 text-sm text-moss hover:text-terra transition-colors">
                <span>View all cities</span>
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            </div>

            <div class="bg-cream-50 border border-moss/10 p-8">
              <p class="eyebrow mb-4">Special requests</p>
              <p class="text-ink/75 leading-relaxed text-sm">
                Eco-friendly products, specific supplies, pet-safe routines, or anything else you want us to know — add a note during booking or give us a call. We'll accommodate.
              </p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>
