---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { site } from '../config.js';
---

<Base 
  title="Contact"
  description="Get a free quote for house or office cleaning. We respond within 24 hours — usually much faster."
>
  <PageHero
    eyebrow="Get in touch"
    title="Tell us about your space."
    description="Free, no-pressure quote. We'll ask a few quick questions, give you a clear price, and let you decide from there."
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Contact', href: '/contact/' }
    ]}
  />

  <section class="py-20 lg:py-28">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-7">
          <form id="contact-form" class="space-y-6">
            <!-- Honeypot - bots will fill this, humans won't see it -->
            <input 
              type="checkbox" 
              name="botcheck" 
              tabindex="-1" 
              autocomplete="off"
              style="position:absolute;left:-9999px;opacity:0;"
              aria-hidden="true"
            />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <label class="block">
                <span class="block text-sm font-medium text-moss mb-2">Your name</span>
                <input
                  type="text"
                  name="name"
                  required
                  class="w-full px-4 py-3.5 bg-cream border border-moss/20 focus:border-moss focus:outline-none transition-colors text-ink placeholder:text-ink/30"
                  placeholder="Jane Doe"
                />
              </label>
              <label class="block">
                <span class="block text-sm font-medium text-moss mb-2">Email</span>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full px-4 py-3.5 bg-cream border border-moss/20 focus:border-moss focus:outline-none transition-colors text-ink placeholder:text-ink/30"
                  placeholder="you@example.com"
                />
              </label>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <label class="block">
                <span class="block text-sm font-medium text-moss mb-2">Phone</span>
                <input
                  type="tel"
                  name="phone"
                  class="w-full px-4 py-3.5 bg-cream border border-moss/20 focus:border-moss focus:outline-none transition-colors text-ink placeholder:text-ink/30"
                  placeholder="(281) 555-0123"
                />
              </label>
              <label class="block">
                <span class="block text-sm font-medium text-moss mb-2">City</span>
                <input
                  type="text"
                  name="city"
                  class="w-full px-4 py-3.5 bg-cream border border-moss/20 focus:border-moss focus:outline-none transition-colors text-ink placeholder:text-ink/30"
                  placeholder="Spring, TX"
                />
              </label>
            </div>

            <label class="block">
              <span class="block text-sm font-medium text-moss mb-2">What service are you interested in?</span>
              <select
                name="service"
                class="w-full px-4 py-3.5 bg-cream border border-moss/20 focus:border-moss focus:outline-none transition-colors text-ink"
              >
                <option value="">Select a service</option>
                <option value="Recurring Maid Service">Recurring maid service</option>
                <option value="Deep Cleaning">Deep cleaning</option>
                <option value="Move-In / Move-Out">Move-in / move-out</option>
                <option value="Office Cleaning">Office cleaning</option>
                <option value="Eco-Friendly">Eco-friendly cleaning</option>
                <option value="Not sure">Not sure yet</option>
              </select>
            </label>

            <label class="block">
              <span class="block text-sm font-medium text-moss mb-2">Tell us about your space</span>
              <textarea
                name="message"
                rows="5"
                class="w-full px-4 py-3.5 bg-cream border border-moss/20 focus:border-moss focus:outline-none transition-colors text-ink placeholder:text-ink/30 resize-none"
                placeholder="Bedrooms, bathrooms, square footage if you know it, special requests, preferred schedule, etc."
              ></textarea>
            </label>

            <button type="submit" id="submit-btn" class="btn-accent w-full md:w-auto">
              <span id="btn-text">Send my request</span>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </button>

            <p class="text-xs text-ink/50">
              Your info goes straight to our inbox. We never share it with anyone.
            </p>

            <!-- Success / error state -->
            <div id="form-result" class="hidden"></div>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-5 lg:pl-8">
          <div class="sticky top-24 space-y-8">
            <div class="bg-moss text-cream p-8 lg:p-10 relative overflow-hidden">
              <div class="absolute -bottom-10 -right-10 w-40 h-40 rounded-full bg-terra/20 blur-3xl"></div>
              <div class="relative">
                <p class="eyebrow text-terra-200 mb-4">Prefer to call?</p>
                <a 
                  href={`tel:${site.phoneTel}`}
                  class="font-display text-3xl lg:text-4xl hover:text-terra-200 transition-colors block"
                >
                  {site.phone}
                </a>
                <p class="mt-6 eyebrow text-terra-200 mb-3">Or email us</p>
                <a 
                  href={`mailto:${site.email}`}
                  class="text-cream/90 hover:text-terra-200 transition-colors break-all"
                >
                  {site.email}
                </a>
                <p class="mt-6 text-cream/70 leading-relaxed text-sm">
                  We respond to every inquiry within one business day — usually much faster.
                </p>
              </div>
            </div>

            <div class="bg-cream-200 border border-moss/10 p-8">
              <p class="eyebrow mb-4">Service hours</p>
              <p class="font-display text-xl text-moss leading-tight mb-2">
                {site.hours}
              </p>
              <p class="text-sm text-ink/60 leading-relaxed">
                Closed Sundays. Scheduling windows may vary seasonally.
              </p>
            </div>

            <div class="bg-cream-50 border border-moss/10 p-8">
              <p class="eyebrow mb-4">Service area</p>
              <p class="text-ink/75 leading-relaxed text-sm">
                {site.serviceArea}.
              </p>
              <a href="/cities/" class="mt-4 inline-flex items-center gap-1 text-sm text-moss hover:text-terra transition-colors">
                <span>View all cities</span>
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const result = document.getElementById('form-result');
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (btn) btn.disabled = true;
    if (btnText) btnText.textContent = 'Sending...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const json = await response.json();

      if (result) {
        result.classList.remove('hidden');
        if (response.ok && json.success) {
          result.className = 'mt-4 p-5 bg-moss text-cream text-sm';
          result.innerHTML = '<p class="font-medium">Got it! Your message is on its way.</p><p class="mt-1 text-cream/80">We\'ll be in touch within one business day.</p>';
          form.reset();
        } else {
          result.className = 'mt-4 p-4 bg-terra/10 border border-terra/30 text-sm text-terra-700';
          result.textContent = json.message || 'Something went wrong. Please try emailing us directly.';
        }
      }
    } catch (err) {
      if (result) {
        result.classList.remove('hidden');
        result.className = 'mt-4 p-4 bg-terra/10 border border-terra/30 text-sm text-terra-700';
        result.textContent = 'Something went wrong. Please try emailing us directly at info@springhousecleaners.com.';
      }
    } finally {
      if (btn) btn.disabled = false;
      if (btnText) btnText.textContent = 'Send my request';
    }
  });
</script>
