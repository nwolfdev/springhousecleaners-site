---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Icon from '../components/Icon.astro';
import { services, cities, site } from '../config.js';

const homepageFAQs = [
  {
    question: "What cities do you clean in?",
    answer: "We serve the greater Houston area, including Spring, The Woodlands, Tomball, Conroe, Cypress, Cypress Station, Humble, Magnolia, Montgomery, New Caney, Porter, Willis, and Egypt. If your city is nearby and isn't on the list, send us a message — we occasionally take on homes outside our standard radius."
  },
  {
    question: "How much does a cleaning cost?",
    answer: "Pricing depends on home size, condition, and the type of service (recurring, deep, or move-in/out). A typical recurring clean for a 2-3 bedroom home in the Houston area runs $140–$220 per visit. You can get an instant quote and book directly on our booking page — no back-and-forth, no surprise fees."
  },
  {
    question: "Do I need to provide cleaning supplies?",
    answer: "No. We bring everything — professional-grade cleaning products and all equipment. If you'd prefer we use eco-friendly or non-toxic products (common for customers with chemical sensitivities, newborns, or pets), just let us know when booking and we'll accommodate."
  },
  {
    question: "Are you licensed and insured?",
    answer: "Yes. Spring Cleaning is a licensed, bonded, and insured cleaning company for both residential and commercial work. Every team member is background-checked before they ever step into a customer's home."
  },
  {
    question: "Will I get the same cleaner every time?",
    answer: "Whenever possible, yes. We keep our team small specifically so recurring customers see the same faces week after week. The cleaner who learns your home — where your dog's water bowl lives, which bookshelf you'd rather not be touched — is a different experience than rolling a new person through your door every visit."
  },
  {
    question: "What makes Spring Cleaning different from other Houston cleaning services?",
    answer: "Three things. First, we're small by design — Jordan and Sofia started the company because they couldn't find a reliable cleaner themselves, and we've stayed tight so we don't repeat the mistakes that frustrated them. Second, we pick up the phone. No automated scheduling portals, no 'we'll get back to you in 48 hours.' Real humans, real communication. Third, we back it up — a 4.8-star average on Google and a satisfaction guarantee on every clean."
  },
  {
    question: "How do I book a cleaning?",
    answer: "The fastest way is to book directly through our booking page — pick your service, see pricing, and schedule in a few minutes. You can also call us at (832) 224-6617 or email info@springhousecleaners.com if you'd rather talk to a human first."
  }
];
---

<Base>
  <!-- HERO -->
  <section class="relative pt-16 lg:pt-24 pb-24 lg:pb-36 overflow-hidden">
    <!-- Soft atmospheric background -->
    <div class="absolute top-1/4 -left-40 w-[32rem] h-[32rem] rounded-full bg-moss/[0.06] blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/3 -right-40 w-[28rem] h-[28rem] rounded-full bg-terra/[0.04] blur-3xl pointer-events-none"></div>

    <div class="container-custom relative">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow mb-6 opacity-0 animate-fade-up" style="animation-delay: 100ms;">
            Houston-area home & office cleaning
          </p>
          <h1 
            class="font-display text-display-xl text-moss leading-[0.92] tracking-tight opacity-0 animate-fade-up"
            style="animation-delay: 200ms;"
          >
            A home, made<br>
            to feel like<br>
            <span class="italic text-terra font-light">one again.</span>
          </h1>
        </div>
        <div class="lg:col-span-4 opacity-0 animate-fade-up" style="animation-delay: 500ms;">
          <p class="text-lg text-ink/70 leading-relaxed max-w-sm">
            Real humans. Real care. A cleaning crew you'll actually want to see again — serving Spring, The Woodlands, and Tomball since 2023.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact/" class="btn-primary">
              Book a cleaning
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
            <a href="/services/" class="btn-outline">
              Our services
            </a>
          </div>
        </div>
      </div>

      <!-- Stat strip -->
      <div class="mt-24 lg:mt-32 grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 pt-12 border-t border-moss/15">
        <div class="opacity-0 animate-fade-up" style="animation-delay: 700ms;">
          <div class="font-display text-4xl lg:text-5xl text-moss">★ 4.8</div>
          <p class="mt-2 text-sm text-ink/60">Google-verified rating · 17 reviews</p>
        </div>
        <div class="opacity-0 animate-fade-up" style="animation-delay: 800ms;">
          <div class="font-display text-4xl lg:text-5xl text-moss">13</div>
          <p class="mt-2 text-sm text-ink/60">Texas communities served</p>
        </div>
        <div class="opacity-0 animate-fade-up" style="animation-delay: 900ms;">
          <div class="font-display text-4xl lg:text-5xl text-moss">100%</div>
          <p class="mt-2 text-sm text-ink/60">Satisfaction guaranteed</p>
        </div>
        <div class="opacity-0 animate-fade-up" style="animation-delay: 1000ms;">
          <div class="font-display text-4xl lg:text-5xl text-moss">Insured<span class="text-terra">·</span></div>
          <p class="mt-2 text-sm text-ink/60">Licensed, bonded, and insured</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-24 lg:py-32 bg-cream-50 border-y border-moss/10">
    <div class="container-custom">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16 lg:mb-20">
        <SectionHeading
          eyebrow="What we do"
          title="Cleaning, the way it should be."
          description="Five focused services. Each one tuned to what your space actually needs — not a one-size-fits-all checklist."
        />
        <a href="/services/" class="text-moss hover:text-terra transition-colors text-sm font-medium inline-flex items-center gap-1 group">
          <span>See all services</span>
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {services.map((s, i) => (
          <ServiceCard
            slug={s.slug}
            title={s.title}
            tagline={s.tagline}
            icon={s.icon}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section class="py-24 lg:py-32">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-5">
          <!-- Founders photo -->
          <div class="relative aspect-[4/5] overflow-hidden">
            <img 
              src="/founders.jpg" 
              alt="Jordan and Sofia, founders of Spring Cleaning" 
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <!-- Dark gradient for caption legibility -->
            <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-moss via-moss/70 to-transparent"></div>
            <!-- Accent glow -->
            <div class="absolute -top-20 -right-20 w-60 h-60 rounded-full bg-terra/20 blur-3xl mix-blend-overlay"></div>
            <div class="absolute bottom-6 left-6 right-6 text-cream">
              <p class="eyebrow text-terra-200 mb-3">Meet the founders</p>
              <p class="font-display text-3xl leading-tight">Jordan & Sofia</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7">
          <SectionHeading
            eyebrow="Our story"
            title="Started by a couple who couldn't find a cleaner they trusted."
            size="md"
          />
          <div class="mt-8 space-y-5 text-ink/75 text-lg leading-relaxed max-w-xl">
            <p>
              Jordan spent a decade running a nationwide company. Sofia built her own business in Mexico. When they landed in Spring, Texas together and tried to hire a house cleaner, what they found was chaos — missed appointments, half-finished jobs, and communication that felt like pulling teeth.
            </p>
            <p>
              So they built the company they wished existed. A small team that shows up when they say they will, cleans the way you'd clean your own home, and actually picks up the phone when you call.
            </p>
          </div>
          <a href="/about/" class="mt-10 inline-flex items-center gap-2 text-moss hover:text-terra transition-colors font-medium group">
            <span class="relative after:absolute after:left-0 after:-bottom-0.5 after:h-px after:bg-current after:w-full after:origin-right after:scale-x-0 group-hover:after:origin-left group-hover:after:scale-x-100 after:transition-transform after:duration-300">
              Read the full story
            </span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <Testimonials />

  <!-- CITIES -->
  <section class="py-24 lg:py-32">
    <div class="container-custom">
      <div class="max-w-3xl mb-16">
        <SectionHeading
          eyebrow="Service area"
          title="Thirteen communities. One standard."
          description="We serve homes and businesses across the greater Houston area — from our hometown of Spring out to Conroe, Magnolia, and The Woodlands."
          size="md"
        />
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-px bg-moss/10 border border-moss/10">
        {cities.map((city) => (
          <a
            href={`/cities/${city.slug}/`}
            class="group bg-cream-50 p-6 lg:p-8 hover:bg-moss hover:text-cream transition-all duration-300 flex flex-col justify-between min-h-[140px]"
          >
            <p class="font-display text-xl lg:text-2xl leading-tight">
              {city.name}
            </p>
            <div class="mt-4 flex items-center gap-1.5 text-xs opacity-60 group-hover:opacity-100 transition-opacity">
              <span>View area</span>
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ - critical for AI search + rich snippets -->
  <FAQ 
    eyebrow="Common questions"
    title="What people ask before booking."
    description="The questions we get most often from new customers. Still have something to ask? Call us at (832) 224-6617 — we actually pick up."
    items={homepageFAQs}
  />

  <!-- CTA -->
  <CTA />
</Base>
