---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTA from '../../components/CTA.astro';
import { services } from '../../config.js';
---

<Base 
  title="House & Office Cleaning Services in Houston, TX"
  description="Professional home and commercial cleaning services in the Houston area: recurring maid service, deep cleaning, move-in/out, office cleaning, and eco-friendly options. Serving Spring, The Woodlands, and Tomball since 2023."
>
  <PageHero
    eyebrow="What we do"
    title="Cleaning services, tailored to your space."
    description="Five focused services, each designed around how people actually live and work. Pick what fits — or mix and match with our team."
  />

  <section class="py-24 lg:py-32">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {services.map((s, i) => (
          <ServiceCard
            slug={s.slug}
            title={s.title}
            tagline={s.tagline}
            icon={s.icon}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Base>
