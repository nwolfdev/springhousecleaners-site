---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import Icon from '../../components/Icon.astro';
import { cities, services } from '../../config.js';

export async function getStaticPaths() {
  const entries = await getCollection('cities');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const cityInfo = cities.find(c => c.slug === entry.slug);
const cityName = cityInfo?.name || entry.data.city;

const seoTitle = `House Cleaning Services in ${cityName}, TX | Spring Cleaning`;
const description = `Top-rated house and office cleaning services in ${cityName}, Texas. Recurring maid service, deep cleaning, move-in/out, and eco-friendly options. 4.8★ on Google. Free quotes — call (832) 224-6617.`;

const otherCities = cities.filter(c => c.slug !== entry.slug).slice(0, 6);

// Per-city FAQ (huge for AI search on "best cleaner in [city]" queries)
const cityFAQs = [
  {
    question: `Do you clean homes in ${cityName}, Texas?`,
    answer: `Yes — ${cityName} is part of our regular Houston-area service zone. We serve residential and commercial customers throughout ${cityName}, including recurring maid service, deep cleaning, move-in/move-out cleaning, and office cleaning.`
  },
  {
    question: `How much does house cleaning cost in ${cityName}?`,
    answer: `Pricing depends on home size and the type of service. A typical recurring clean for a 2-3 bedroom home in the ${cityName} area runs $140–$220 per visit. Deep cleans run higher because they take longer. You can see exact pricing and book directly through our booking page — no back-and-forth, no surprise fees.`
  },
  {
    question: `What's the best cleaning service in ${cityName}, TX?`,
    answer: `We're biased, but here's what people tell us: Spring Cleaning stands out in ${cityName} for consistency (same cleaner whenever possible), showing up on time every time, clear communication, and a real human on the other end of the phone. We maintain a 4.8-star average on Google and keep our team small by design so every ${cityName} home gets the attention it deserves.`
  },
  {
    question: `Are you licensed and insured to clean in ${cityName}?`,
    answer: `Yes, Spring Cleaning is fully licensed, bonded, and insured to operate in ${cityName} and throughout Texas. Every cleaner on our team is background-checked before they enter a customer's home.`
  },
  {
    question: `How do I book a cleaning in ${cityName}?`,
    answer: `The fastest way is to book directly through our booking page — pick your service, see pricing, and schedule in a few minutes. You can also call (832) 224-6617 or email info@springhousecleaners.com. First-time ${cityName} customers often start with a deep clean, then switch to recurring service from there.`
  }
];

// Service schema specific to this city
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "House Cleaning",
  "name": `House Cleaning Services in ${cityName}, TX`,
  "description": description,
  "provider": {
    "@type": "HouseholdCleaningService",
    "name": "Spring Cleaning",
    "telephone": "(832) 224-6617",
    "url": "https://springhousecleaners.com",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": 4.8,
      "reviewCount": 17
    }
  },
  "areaServed": {
    "@type": "City",
    "name": `${cityName}, TX`
  }
};
---

<Base title={seoTitle} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <PageHero
    eyebrow={`${cityName}, Texas`}
    title={`Cleaning services in ${cityName}.`}
    description={`The same trusted cleaning team you'd hire for your own home — now serving ${cityName} and the surrounding area. Recurring, deep clean, move-in/out, and more.`}
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Service Area', href: '/cities/' },
      { label: cityName, href: `/cities/${entry.slug}/` }
    ]}
  />

  <!-- Intro -->
  <section class="py-20 lg:py-28">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-5">Why {cityName}</p>
          <h2 class="font-display text-display-md text-moss leading-[1.05]">
            A cleaning service that actually shows up — <span class="italic text-terra">and stays.</span>
          </h2>
          <div class="mt-8 space-y-5 text-ink/75 text-lg leading-relaxed max-w-xl">
            <p>
              We started Spring Cleaning because we, ourselves, couldn't find a cleaner in {cityName} and the surrounding Houston-area communities we could trust week after week. Missed appointments, rotating crews, no communication — we've heard every story.
            </p>
            <p>
              So we built what we wished existed: a small, vetted team that treats {cityName} homes like their own. Same cleaner, every visit (whenever possible). Clear communication. Eco-friendly products. And a free, no-pressure quote before you commit to anything.
            </p>
          </div>
        </div>
        <div class="lg:col-span-5 lg:pl-4">
          <div class="bg-cream-200 border border-moss/10 p-8 lg:p-10">
            <p class="eyebrow mb-5">What {cityName} gets</p>
            <ul class="space-y-4">
              {[
                'Background-checked, trained team',
                'Eco-friendly, plant-based products',
                'Same cleaner, every visit (whenever possible)',
                'Satisfaction guaranteed or we come back',
                'Flexible scheduling: weekly, bi-weekly, or monthly',
                'Free, detailed quote before we start'
              ].map(item => (
                <li class="flex gap-3 items-start">
                  <Icon name="check" class="w-5 h-5 text-terra shrink-0 mt-0.5" />
                  <span class="text-ink/85">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services available in this city -->
  <section class="py-20 lg:py-28 bg-cream-50 border-y border-moss/10">
    <div class="container-custom">
      <div class="max-w-2xl mb-14">
        <p class="eyebrow mb-5">In {cityName}</p>
        <h2 class="font-display text-display-md text-moss leading-[1.05]">
          All five services, available locally.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-moss/10 border border-moss/10">
        {services.map(s => (
          <a href={`/services/${s.slug}/`} class="group block bg-cream-50 p-6 lg:p-7 hover:bg-moss hover:text-cream transition-all duration-300">
            <div class="w-10 h-10 flex items-center justify-center bg-moss/5 group-hover:bg-cream/10 rounded-full mb-5 transition-colors">
              <Icon name={s.icon as any} class="w-5 h-5 text-moss group-hover:text-cream transition-colors" />
            </div>
            <p class="font-display text-lg leading-tight mb-1">{s.shortTitle}</p>
            <p class="text-xs text-ink/50 group-hover:text-cream/60 transition-colors mt-3 flex items-center gap-1">
              <span>Learn more</span>
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial strip -->
  <section class="py-20 lg:py-24">
    <div class="container-custom">
      <figure class="max-w-3xl">
        <div class="flex gap-0.5 mb-6 text-terra">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <blockquote class="font-display text-2xl lg:text-3xl text-moss leading-[1.25]">
          "Fantastic job done and great customer service! I'll be using them from here on out, the place was spotless and they handled everything with care!"
        </blockquote>
        <figcaption class="mt-6 text-sm text-ink/60">
          — N. Sneed · Google review
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- Nearby cities -->
  <section class="py-16 lg:py-20 bg-cream-50 border-t border-moss/10">
    <div class="container-custom">
      <p class="eyebrow mb-5">Also serving nearby</p>
      <div class="flex flex-wrap gap-2">
        {otherCities.map(c => (
          <a href={`/cities/${c.slug}/`} class="inline-flex items-center px-4 py-2 border border-moss/20 text-sm text-moss hover:bg-moss hover:text-cream transition-colors rounded-full">
            {c.name}
          </a>
        ))}
        <a href="/cities/" class="inline-flex items-center px-4 py-2 text-sm text-terra hover:text-moss transition-colors">
          View all →
        </a>
      </div>
    </div>
  </section>

  <!-- City-specific FAQ for local SEO + AI search -->
  <FAQ 
    eyebrow="Good questions"
    title={`Cleaning in ${cityName}, answered.`}
    items={cityFAQs}
  />

  <CTA 
    title={`Ready for a cleaner home in ${cityName}?`}
    description="Free quote, zero pressure. We'll walk through what you need and what it costs — then you decide."
  />
</Base>
