---
import Icon from './Icon.astro';
export interface Props {
  slug: string;
  title: string;
  tagline: string;
  icon: string;
  index?: number;
}
const { slug, title, tagline, icon, index = 0 } = Astro.props;
---

<a 
  href={`/services/${slug}/`}
  class="group relative flex flex-col p-8 lg:p-10 bg-cream-50 border border-moss/10 hover:border-moss/30 hover:-translate-y-1 transition-all duration-300 overflow-hidden"
  style={`animation-delay: ${index * 80}ms`}
>
  <!-- Subtle accent corner -->
  <div class="absolute top-0 right-0 w-24 h-24 bg-moss/[0.03] rounded-bl-full transition-all duration-500 group-hover:bg-terra/10 group-hover:w-32 group-hover:h-32"></div>

  <div class="relative flex items-center justify-between mb-8">
    <div class="w-14 h-14 flex items-center justify-center bg-moss text-cream rounded-full transition-all duration-300 group-hover:bg-terra">
      <Icon name={icon as any} class="w-6 h-6" />
    </div>
    <span class="text-xs font-mono text-moss/30">0{(index + 1)}</span>
  </div>

  <h3 class="font-display text-2xl lg:text-[1.75rem] text-moss leading-tight mb-3">
    {title}
  </h3>
  <p class="text-ink/70 leading-relaxed text-[0.95rem] flex-1">
    {tagline}
  </p>

  <div class="mt-6 flex items-center gap-2 text-sm font-medium text-moss">
    <span class="relative after:content-[''] after:absolute after:left-0 after:-bottom-0.5 after:w-full after:h-px after:bg-moss after:origin-right after:scale-x-0 group-hover:after:origin-left group-hover:after:scale-x-100 after:transition-transform after:duration-300">
      Learn more
    </span>
    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
      <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
</a>
