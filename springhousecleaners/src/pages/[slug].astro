---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  // Only render privacy-policy and terms-of-service here; other pages have their own routes
  const genericSlugs = ['privacy-policy', 'terms-of-service'];
  return pages
    .filter(p => genericSlugs.includes(p.slug))
    .map(page => ({
      params: { slug: page.slug },
      props: { page }
    }));
}

const { page } = Astro.props;
const { Content } = await page.render();
---

<Base title={page.data.title} noindex={false}>
  <PageHero
    eyebrow="Legal"
    title={page.data.title}
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: page.data.title, href: `/${page.slug}/` }
    ]}
  />

  <section class="py-20 lg:py-24">
    <div class="container-custom">
      <div class="max-w-prose-lg">
        <div class="prose-custom">
          <Content />
        </div>
      </div>
    </div>
  </section>
</Base>
