---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import Icon from '../components/Icon.astro';
---

<Base 
  title="About Us"
  description="Spring Cleaning was founded by Jordan and Sofia — a couple who couldn't find a cleaning service they trusted, so they built their own. Based in Spring, Texas."
>
  <PageHero
    eyebrow="Our story"
    title="Built by a couple who couldn't find a cleaner they trusted."
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'About', href: '/about/' }
    ]}
  />

  <!-- The story -->
  <section class="py-20 lg:py-28">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-5">
          <div class="sticky top-24">
            <div class="relative aspect-[4/5] bg-moss overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-cream/10 font-display text-[14rem] leading-none select-none">J&S</div>
              </div>
              <div class="absolute -top-20 -right-20 w-60 h-60 rounded-full bg-terra/20 blur-3xl"></div>
              <div class="absolute bottom-6 left-6 right-6 text-cream">
                <p class="eyebrow text-terra-200 mb-2">Founders</p>
                <p class="font-display text-3xl leading-tight">Jordan & Sofia</p>
                <p class="mt-2 text-sm text-cream/70">Spring, TX · Since July 2023</p>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 space-y-8">
          <div>
            <h2 class="font-display text-display-sm text-moss mb-5">A new beginning.</h2>
            <p class="text-lg text-ink/75 leading-relaxed">
              Jordan has always had an entrepreneurial spirit. For over a decade, he ran a successful nationwide company, pouring his heart and soul into his work. But like many others, the pandemic became a turning point — a chance to reevaluate what actually mattered. The realization that he was missing out on quality time with the people he loved hit hard. It was time for a change.
            </p>
          </div>

          <div>
            <p class="text-lg text-ink/75 leading-relaxed">
              Sofia was a thriving entrepreneur in Mexico, running a produce business that showcased her dedication and determination. Fate brought them together when Sofia was visiting Houston, and love followed. They found their forever home in Spring, Texas — and a shared dream to build something meaningful together.
            </p>
          </div>

          <div>
            <h2 class="font-display text-display-sm text-moss mb-5 pt-6">Building dreams together.</h2>
            <p class="text-lg text-ink/75 leading-relaxed">
              As new homeowners and busy professionals, they faced a challenge that a lot of families know all too well: there was no time to work, spend real moments with each other (and the cats), <em>and</em> keep a clean home.
            </p>
            <p class="mt-5 text-lg text-ink/75 leading-relaxed">
              So they hired cleaning services. Several of them. And the experience was far from satisfactory. Poor communication, inconsistent attendance, and subpar cleaning left them yearning for something better — a service that actually understood what homeowners needed.
            </p>
          </div>

          <div>
            <h2 class="font-display text-display-sm text-moss mb-5 pt-6">A promise to our community.</h2>
            <p class="text-lg text-ink/75 leading-relaxed">
              With their shared experiences and a passion for excellence, Spring Cleaning was born. It's more than a business — it's a commitment to the kind of service we always wished we could find. Reliable. Thorough. Honest.
            </p>
            <p class="mt-5 text-lg text-ink/75 leading-relaxed">
              Today, we serve thirteen communities across the greater Houston area, with a small, vetted team that treats your home like their own. We built the company we wished existed. And we'd love to show you what that looks like.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values grid -->
  <section class="py-20 lg:py-28 bg-cream-50 border-y border-moss/10">
    <div class="container-custom">
      <div class="max-w-2xl mb-14">
        <p class="eyebrow mb-5">What we stand for</p>
        <h2 class="font-display text-display-md text-moss leading-[1.05]">
          Principles, not pitches.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {[
          {
            title: 'Show up when we say',
            description: 'If we book a 10am appointment, we\'re there at 10am. If something changes, you hear from us immediately.',
            icon: 'check'
          },
          {
            title: 'Treat it like our home',
            description: 'We clean every space with the care we\'d give our own. No shortcuts. No half-finished rooms.',
            icon: 'spark'
          },
          {
            title: 'Use what\'s safe',
            description: 'Plant-based, non-toxic products are our default. Safe for kids, pets, and anyone with allergies.',
            icon: 'leaf'
          },
          {
            title: 'Stand behind our work',
            description: 'If something isn\'t right, we come back and fix it. Full stop. Your satisfaction is non-negotiable.',
            icon: 'recurring'
          }
        ].map((value, i) => (
          <div class="relative">
            <div class="w-12 h-12 flex items-center justify-center bg-moss text-cream rounded-full mb-5">
              <Icon name={value.icon as any} class="w-5 h-5" />
            </div>
            <p class="text-xs font-mono text-moss/30 mb-3">0{i + 1}</p>
            <h3 class="font-display text-xl lg:text-2xl text-moss leading-tight mb-3">
              {value.title}
            </h3>
            <p class="text-ink/70 text-[0.95rem] leading-relaxed">
              {value.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA 
    title="Meet the team that cleans like it's their own home."
    description="Book a free quote and experience the difference a team that actually cares makes."
  />
</Base>
